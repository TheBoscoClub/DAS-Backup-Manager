[Unit]
Description=DAS Backup Timer - Nightly incremental backup at 3 AM
Documentation=file:///hddRaid1/ClaudeCodeProjects/DAS-Backup-Manager/docs/OFFLINE-BACKUP-PLAN.md

[Timer]
# Run at 3 AM daily
OnCalendar=*-*-* 03:00:00
# Randomize start by up to 30 minutes to avoid exact timing
RandomizedDelaySec=1800
# If system was off at scheduled time, run on next boot
Persistent=true
# Wake system from sleep for backup (if supported)
WakeSystem=false

[Install]
WantedBy=timers.target
