[Unit]
Description=DAS Full Backup Timer - Weekly full boot subvolume refresh
Documentation=file:///hddRaid1/ClaudeCodeProjects/DAS-Backup-Manager/docs/OFFLINE-BACKUP-PLAN.md

[Timer]
# Run every Sunday at 4 AM
OnCalendar=Sun *-*-* 04:00:00
RandomizedDelaySec=1800
Persistent=true

[Install]
WantedBy=timers.target
