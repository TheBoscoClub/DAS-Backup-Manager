#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_configure:
	. $(HOME)/.cargo/env 2>/dev/null; cmake -B build -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_BUILD_TYPE=Release

override_dh_auto_build:
	. $(HOME)/.cargo/env 2>/dev/null; cmake --build build

override_dh_auto_install:
	DESTDIR=$(CURDIR)/debian/das-backup-manager cmake --install build

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info || true
