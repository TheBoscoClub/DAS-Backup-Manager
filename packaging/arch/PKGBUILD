# Maintainer: TheBoscoClub <theboscoclub@users.noreply.github.com>
pkgname=das-backup-manager
pkgver=0.5.0
pkgrel=1
pkgdesc='DAS backup manager with btrbk integration, SQLite FTS5 content indexing, and KDE Plasma GUI'
arch=('x86_64')
url='https://github.com/TheBoscoClub/DAS-Backup-Manager'
license=('MIT')
depends=('btrbk' 'btrfs-progs' 'smartmontools' 'zsh' 'util-linux'
         'qt6-base' 'kcoreaddons' 'ki18n' 'kxmlgui'
         'kconfigwidgets' 'kiconthemes' 'kcrash' 'kio')
makedepends=('rust' 'cmake' 'extra-cmake-modules' 'qt6-tools')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "DAS-Backup-Manager-$pkgver"

    # Strip GCC LTO flags — GCC LTO bitcode is incompatible with LLVM's lld
    # linker used by rustc, causing undefined sqlite3_* symbols when linking
    # the bundled libsqlite3-sys static archive
    export CFLAGS="${CFLAGS//-flto=auto/}"
    export CXXFLAGS="${CXXFLAGS//-flto=auto/}"
    export LDFLAGS="${LDFLAGS//-flto=auto/}"

    # Build Rust indexer binary
    cargo build --release --manifest-path indexer/Cargo.toml

    # Build scripts, systemd units, and GUI via CMake
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_INDEXER=OFF
    cmake --build build
}

package() {
    cd "DAS-Backup-Manager-$pkgver"

    # Install CMake targets (scripts, systemd, GUI, icon, desktop entry)
    DESTDIR="$pkgdir" cmake --install build

    # Install Rust binary
    install -Dm755 "indexer/target/release/btrdasd" "$pkgdir/usr/bin/btrdasd"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
