# Maintainer: TheBoscoClub <theboscoclub@users.noreply.github.com>
pkgname=das-backup-manager
pkgver=0.7.8
pkgrel=1
pkgdesc='DAS backup manager with btrbk integration, SQLite FTS5 content indexing, and KDE Plasma GUI'
arch=('x86_64')
url='https://github.com/TheBoscoClub/DAS-Backup-Manager'
license=('MIT')
depends=('btrbk' 'btrfs-progs' 'smartmontools' 'bash' 'util-linux'
         'qt6-base' 'qt6-charts' 'kcoreaddons' 'ki18n' 'kxmlgui'
         'kconfigwidgets' 'kiconthemes' 'kcrash' 'kio'
         'knotifications' 'kstatusnotifieritem')
optdepends=('s-nail: email backup reports (mailx)'
            'rsync: ESP/boot partition mirroring'
            'mbuffer: buffered btrbk stream transfers')
makedepends=('rust' 'cmake' 'extra-cmake-modules' 'qt6-tools')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "DAS-Backup-Manager-$pkgver"

    # Strip GCC LTO flags — GCC LTO bitcode is incompatible with LLVM's lld
    # linker used by rustc, causing undefined sqlite3_* symbols when linking
    # the bundled libsqlite3-sys static archive
    export CFLAGS="${CFLAGS//-flto=auto/}"
    export CXXFLAGS="${CXXFLAGS//-flto=auto/}"
    export LDFLAGS="${LDFLAGS//-flto=auto/}"

    # Build Rust indexer binary
    cargo build --release --features dbus --manifest-path indexer/Cargo.toml

    # Build scripts, systemd units, and GUI via CMake
    cmake -B build -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_INDEXER=OFF
    cmake --build build
}

package() {
    cd "DAS-Backup-Manager-$pkgver"

    # Install CMake targets (scripts, systemd, GUI, icon, desktop entry)
    DESTDIR="$pkgdir" cmake --install build

    # Install Rust binaries
    install -Dm755 "indexer/target/release/btrdasd" "$pkgdir/usr/bin/btrdasd"
    install -Dm755 "indexer/target/release/btrdasd-helper" "$pkgdir/usr/libexec/btrdasd-helper"

    # D-Bus and polkit integration
    install -Dm644 "dbus/org.dasbackup.Helper1.conf" "$pkgdir/usr/share/dbus-1/system.d/org.dasbackup.Helper1.conf"
    install -Dm644 "dbus/org.dasbackup.Helper1.service" "$pkgdir/usr/share/dbus-1/system-services/org.dasbackup.Helper1.service"
    install -Dm644 "polkit/org.dasbackup.policy" "$pkgdir/usr/share/polkit-1/actions/org.dasbackup.policy"
    install -Dm644 "systemd/btrdasd-helper.service" "$pkgdir/usr/lib/systemd/system/btrdasd-helper.service"

    # License
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
